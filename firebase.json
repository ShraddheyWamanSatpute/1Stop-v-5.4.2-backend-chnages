{
  "hosting": [
    {
      "target": "test",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/assistant", "function": "assistantGateway" },
        { "source": "/api/ops", "function": "opsRouter" },
        { "source": "/api/ops/**", "function": "opsRouter" },
        { "source": "/api/version", "destination": "/version.json" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "/version.json",
          "headers": [
            { "key": "Access-Control-Allow-Origin", "value": "*" },
            { "key": "Cache-Control", "value": "no-store" }
          ]
        },
        {
          "source": "**/*.@(js|css|woff2|ico|png|jpg|svg)",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        },
        { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
      ]
    },
    {
      "target": "live",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/assistant", "function": "assistantGateway" },
        { "source": "/api/ops", "function": "opsRouter" },
        { "source": "/api/ops/**", "function": "opsRouter" },
        { "source": "/api/version", "destination": "/version.json" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "/version.json",
          "headers": [
            { "key": "Access-Control-Allow-Origin", "value": "*" },
            { "key": "Cache-Control", "value": "no-store" }
          ]
        },
        {
          "source": "**/*.@(js|css|woff2|ico|png|jpg|svg)",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        },
        { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
      ]
    }
  ],
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "functions": {
      "port": 5002
    },
    "database": {
      "port": 9000
    },
    "ui": {
      "enabled": false
    }
  }
}
