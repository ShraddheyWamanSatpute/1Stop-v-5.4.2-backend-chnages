# HMRC Integration Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# HMRC OAuth Client ID (from HMRC Developer Hub)
# Get this from: https://developer.service.hmrc.gov.uk/developer/applications
VITE_HMRC_CLIENT_ID=your_client_id_here

# HMRC OAuth Client Secret (from HMRC Developer Hub)
# Keep this secure and never commit it to version control
VITE_HMRC_CLIENT_SECRET=your_client_secret_here

# HMRC Redirect URI (optional - defaults to /hmrc/callback)
# This should match the redirect URI configured in HMRC Developer Hub
# VITE_HMRC_REDIRECT_URI=/hmrc/callback
# HMRC Redirect URI + scope (recommended)
VITE_HMRC_REDIRECT_URI=http://localhost:5173/hmrc/callback
VITE_HMRC_OAUTH_SCOPE=hello

# =========================
# Google (optional)
# =========================
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
VITE_GOOGLE_REDIRECT_URI=your_google_oauth_redirect_uri_here

# =========================
# Firebase (required)
# =========================
# Keep these in `.env.local` (do not commit real values).
VITE_FIREBASE_ENV=main
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
# Optional
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# =========================
# Firebase (test environment)
# =========================
VITE_FIREBASE_TEST_API_KEY=your_test_firebase_api_key_here
VITE_FIREBASE_TEST_PROJECT_ID=your_test_firebase_project_id_here
VITE_FIREBASE_TEST_AUTH_DOMAIN=your_test_project_id.firebaseapp.com
VITE_FIREBASE_TEST_DATABASE_URL=https://your_test_project_id-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_TEST_STORAGE_BUCKET=your_test_project_id.appspot.com
VITE_FIREBASE_TEST_MESSAGING_SENDER_ID=your_test_sender_id_here
VITE_FIREBASE_TEST_APP_ID=your_test_app_id_here
# Optional
VITE_FIREBASE_TEST_MEASUREMENT_ID=your_test_measurement_id_here
VITE_FIREBASE_TEST_FUNCTIONS_REGION=us-central1

# =========================
# Supabase (optional)
# =========================
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Data provider selection (firebase/supabase)
VITE_DATA_PROVIDER=supabase

# =========================
# Firebase Hosting (optional)
# =========================
# Use these when you want explicit test vs main hosting project/target values
# for deploy tooling or scripts.
VITE_FIREBASE_HOSTING_PROJECT_MAIN=your_main_firebase_project_id_here
VITE_FIREBASE_HOSTING_TARGET_MAIN=prod
VITE_FIREBASE_HOSTING_PROJECT_TEST=your_test_firebase_project_id_here
VITE_FIREBASE_HOSTING_TARGET_TEST=dev

# =========================
# Firebase Cloud Functions — Ops / GitHub (not Vite)
# =========================
# Configure these in the Firebase Console (Functions secrets / environment) or your functions deploy env.
# They power Ops → Git & code (branches, compare, ZIP) and related workflows — not the Vite admin build.
#
# GITHUB_OWNER=your-org-or-user
# GITHUB_REPO=your-repo-name
# GITHUB_TOKEN=ghp_...   # PAT with repo read (or fine-grained token with contents: read)
# Optional fallbacks (some paths use CI-prefixed names):
# GITHUB_CI_OWNER=
# GITHUB_CI_REPO=
# GITHUB_CI_TOKEN=
# Default branch / ref for downloads and catalog:
# GITHUB_DEFAULT_REF=main
# GITHUB_CI_REF=main
# Workflow dispatch (Actions tab) may also use:
# GITHUB_CI_WORKFLOW=your-workflow.yml
