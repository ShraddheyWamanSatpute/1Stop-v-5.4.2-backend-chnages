{
  "name": "onestop-solutions",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.root.mjs",
    "dev:app": "vite --config vite.config.app.ts",
    "dev:admin": "vite --config vite.config.admin.ts",
    "dev:mobile": "vite --config vite.config.mobile.ts",
    "dev:main-site": "vite --config vite.config.main-site.ts",
    "clean": "node app/backend/scripts/clean.cjs dist app/dist node_modules/.vite",
    "tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "postbuild": "npm run write:version",
    "build:main": "vite build",
    "postbuild:main": "npm run write:version",
    "build:app": "vite build --config vite.config.app.ts",
    "postbuild:app": "npm run write:version",
    "build:admin": "vite build --config vite.config.admin.ts",
    "postbuild:admin": "npm run write:version",
    "build:mobile": "vite build --config vite.config.mobile.ts",
    "postbuild:mobile": "npm run write:version",
    "build:main-site": "vite build --config vite.config.main-site.ts",
    "postbuild:main-site": "npm run write:version",
    "build:all": "npm run build:app && npm run build:admin",
    "postbuild:all": "npm run write:version",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run deploy:test",
    "deploy:test": "npm run build && npx firebase-tools@latest deploy --project test --config app/firebase.json --only hosting,functions",
    "deploy:live": "npm run build && npx firebase-tools@latest deploy --project live --config app/firebase.json --only hosting,functions",
    "deploy:test:app": "npm run build:app && npx firebase-tools@latest deploy --project test --config app/firebase.json --only hosting,functions",
    "deploy:live:app": "npm run build:app && npx firebase-tools@latest deploy --project live --config app/firebase.json --only hosting,functions",
    "deploy:test:admin": "npm run build:admin && npx firebase-tools@latest deploy --project test --config app/firebase.json --only hosting,functions",
    "deploy:live:admin": "npm run build:admin && npx firebase-tools@latest deploy --project live --config app/firebase.json --only hosting,functions",
    "deploy:test:all": "npm run build:all && npx firebase-tools@latest deploy --project test --config app/firebase.json --only hosting,functions",
    "deploy:live:all": "npm run build:all && npx firebase-tools@latest deploy --project live --config app/firebase.json --only hosting,functions",
    "deploy:root:test": "npm run build && npx firebase-tools@latest deploy --project test --config firebase.json --only hosting,functions",
    "deploy:root:live": "npm run build && npx firebase-tools@latest deploy --project live --config firebase.json --only hosting,functions",
    "write:version": "node app/backend/scripts/write-version.cjs && node app/backend/scripts/sync-hosting-dist.cjs",
    "data:generate": "node app/backend/scripts/generate-data-layer.cjs",
    "data:audit": "node app/backend/scripts/audit-data-layer.cjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.21.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emailjs/browser": "^4.4.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@firebase/vertexai": "^1.2.4",
    "@google-cloud/vertexai": "^1.10.0",
    "@iconify/react": "^6.0.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@mui/icons-material": "^5.17.1",
    "@mui/material": "^5.17.1",
    "@mui/x-data-grid": "^7.28.3",
    "@mui/x-date-pickers": "^7.28.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-spring/web": "^10.0.0",
    "@supabase/supabase-js": "^2.103.2",
    "axios": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^2.29.3",
    "dayjs": "^1.11.13",
    "emoji-picker-react": "^4.17.1",
    "firebase": "^11.9.1",
    "framer-motion": "^12.17.0",
    "glob": "^13.0.6",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.562.0",
    "moment": "^2.30.1",
    "nodemailer": "^7.0.10",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.8.69",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-animated-weather": "^4.0.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-big-calendar": "^1.19.2",
    "react-chartjs-2": "^5.3.1",
    "react-color": "^2.19.3",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0",
    "react-firebase-hooks": "^5.1.1",
    "react-redux": "^9.2.0",
    "react-resizable": "^3.0.5",
    "react-rnd": "^10.5.2",
    "react-router-dom": "^6.20.0",
    "recharts": "2.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20.10.0",
    "@types/papaparse": "^5.3.16",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.23",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-color": "^3.0.13",
    "@types/react-dom": "^18.3.7",
    "@types/react-redux": "^7.1.34",
    "@types/react-resizable": "^3.0.8",
    "@types/react-rnd": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-tools": "^12.9.1",
    "globals": "^17.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.5"
  }
}
